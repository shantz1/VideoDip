# =============================================================================
# VideoDip — environment template
#
# Copy to `.env` and fill in. `.env` is gitignored; this file is not.
#
# PLACEHOLDERS ONLY. Never commit a real value here, not even temporarily —
# `git rm --cached` does not remove it from history, and a public repo is
# scraped within minutes.
#
# The desktop editor must run with NONE of these set. Anything here that the
# editor requires to start is a bug against the offline-first guarantee
# (ADR-0002).
# =============================================================================

# --- apps/api (VPS only) -----------------------------------------------------
NODE_ENV=development
API_PORT=3001

# SQLite in development, PostgreSQL on the VPS.
DATABASE_URL=file:./dev.db
# DATABASE_URL=postgresql://user:password@localhost:5432/videodip

# Queue. Local Redis in development.
REDIS_URL=redis://localhost:6379

# Signs API session tokens. Generate: openssl rand -hex 32
AUTH_SECRET=replace-me-with-32-bytes-of-random-hex

# --- apps/web ----------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_* is inlined into the client bundle and is PUBLIC by definition.
# Never put a secret behind this prefix.

# --- Desktop: local AI -------------------------------------------------------
# Paths to locally installed binaries. Left empty, VideoDip discovers them on
# PATH or falls back to its bundled copies.
FFMPEG_PATH=
FFPROBE_PATH=

# Where Whisper weights are cached. Defaults to the OS app-data directory.
WHISPER_MODEL_DIR=
# tiny | base | small | medium | large-v3
WHISPER_MODEL=base

# --- Tauri release signing (CI only) -----------------------------------------
# Never set these locally. The private key signs auto-updates: leaking it lets
# an attacker ship a malicious update to every VideoDip install. It belongs in
# CI secrets and nowhere else.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
