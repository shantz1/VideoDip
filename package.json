{
  "name": "videodip",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, offline-first AI video editing toolkit for short-form creators.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start:videodip": "pnpm --filter @videodip/desktop tauri dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml,css}\"",
    "ai:provision:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/provision-whisper-runtime.ps1",
    "render:provision:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/provision-render-runtime.ps1",
    "render:provision:node:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/provision-node-runtime.ps1",
    "render:stage:release:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/stage-render-resources.ps1",
    "clean": "node scripts/clean-generated.mjs",
    "clean:check": "node scripts/clean-generated.mjs --dry-run",
    "clean:all": "node scripts/clean-generated.mjs --dependencies",
    "whisper:accuracy": "node scripts/whisper-accuracy/run.mjs",
    "verify": "turbo run typecheck lint test"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "rimraf": "6.1.2",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
