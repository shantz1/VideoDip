{
  "name": "@videodip/timeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Timeline data model and operations. Framework-free, undoable by construction.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@videodip/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rimraf": "6.1.2",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
