{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VideoDip",
  "version": "0.1.0",
  "identifier": "com.videodip.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3100",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "VideoDip",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/shantz1/VideoDip/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgwRURBNzRGQTFCOTcwRUUKUldUdWNMbWhUNmZ0Z1B5TVhuY3dXbVZuTkpRSjNsQkYxN05BY3NMQjRXTWNmRVdsWWdlSFY1dm0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
