{
  "name": "@videodip/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The VideoDip marketing site. Static Next.js bundle deployed to the VPS.",
  "scripts": {
    "dev": "next dev --port 3200",
